# Auto-activation for the cad-dl conda env, scoped to this directory.
#
# Requires: direnv (https://direnv.net). One-time per user:
#   brew install direnv
#   add `eval "$(direnv hook bash)"` (or zsh/fish/...) to your shell rc
#   cd into this repo, run `direnv allow`
#
# What this does: prepend the env's bin/ to PATH while inside the project,
# and set the two runtime env vars cad-dl needs. On `cd` out, direnv
# reverts everything.
export MAMBA_ROOT_PREFIX="${MAMBA_ROOT_PREFIX:-$HOME/mamba}"
ENV_BIN="$MAMBA_ROOT_PREFIX/envs/cad-dl/bin"

if [ ! -d "$ENV_BIN" ]; then
  echo "direnv: $ENV_BIN does not exist. Run 'make setup' first." >&2
else
  PATH_add "$ENV_BIN"
fi

export KMP_DUPLICATE_LIB_OK=TRUE
export PYVISTA_OFF_SCREEN=true
